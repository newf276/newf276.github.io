{
    "name": "Forge - Auto Play",
    "plugin": "plugin.video.forge",
    "priority": 500,
    "is_resolvable": "true",
    "play_movie": "executebuiltin://RunPlugin(plugin://plugin.video.forge/?mode=playback.media&media_type=movie&tmdb_id={tmdb}&autoplay=true)",
    "play_episode": "executebuiltin://RunPlugin(plugin://plugin.video.forge/?mode=playback.media&media_type=episode&tmdb_id={tmdb}&season={season}&episode={episode}&autoplay=true)"
}
