<?xml version="1.0" encoding="UTF-8"?>
<window>
    <defaultcontrol always="true">5000</defaultcontrol>
    <allowoverlay>no</allowoverlay>
    <controls>
        <control type="image">
            <left>0</left>
            <top>0</top>
            <width>1920</width>
            <height>1080</height>
            <fadetime>500</fadetime>
            <texture>common/fanart.png</texture>
            <animation effect="fade" start="0" end="100" time="300" tween="sine">WindowOpen</animation>
            <animation effect="fade" end="100" time="200" tween="sine">WindowClose</animation>
        </control>
        <control type="image">
            <left>0</left>
            <top>0</top>
            <width>1920</width>
            <height>1080</height>
            <fadetime>500</fadetime>
            <texture>common/black.png</texture>
            <animation effect="fade" start="0" end="85" time="300" tween="sine">WindowOpen</animation>
            <animation effect="fade" end="85" time="200" tween="sine">WindowClose</animation>
        </control>
        <control type="image">
            <left>880</left>
            <top>473</top>
            <width>160</width>
            <height>160</height>
            <visible>!Container(5000).OnScrollPrevious + !Container(5000).OnScrollNext</visible>
            <animation effect="fade" time="100" delay="650">Visible</animation>
            <texture>fen-spinner.png</texture>
            <animation effect="fade" start="10" time="600" condition="true" pulse="true">Conditional</animation>
            <animation effect="zoom" end="110" time="600" center="auto" condition="true" pulse="true">Conditional</animation>
            <animation effect="rotate" end="-360" time="1200" center="auto" condition="true" loop="true" reversible="false">Conditional</animation>
        </control>
        <control type="list" id="5000">
            <left>-90</left>
            <top>0</top>
            <width>2100</width>
            <height>1080</height>
            <onleft>5000</onleft>
            <onright>5000</onright>
            <ondown>9001</ondown>
            <animation effect="fade" start="0" end="100" time="300" tween="sine">WindowOpen</animation>
            <animation effect="fade" end="100" time="200" tween="sine">WindowClose</animation>
            <scrolltime tween="sine">400</scrolltime>
            <orientation>Horizontal</orientation>
            <itemlayout height="1080" width="1920">
                <control type="image">
                    <left>90</left>
                    <top>0</top>
                    <width>1920</width>
                    <height>1080</height>
                    <aspectratio>keep</aspectratio>
                    <fadetime>200</fadetime>
                    <texture>$INFO[ListItem.Art(fen_slideshow_image)]</texture>
                </control>
            </itemlayout>
            <focusedlayout height="1080" width="1920">
                <control type="image">
                    <left>90</left>
                    <top>0</top>
                    <width>1920</width>
                    <height>1080</height>
                    <aspectratio>keep</aspectratio>
                    <fadetime>200</fadetime>
                    <texture>$INFO[ListItem.Art(fen_slideshow_image)]</texture>
                </control>
            </focusedlayout>
        </control>
    </controls>
</window>
